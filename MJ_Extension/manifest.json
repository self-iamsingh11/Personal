{
  "manifest_version": 3,
  "name": "Midjourney Automator",
  "version": "1.1",
  "description": "Automate prompt extraction and execution on Midjourney via Side Panel",
  "action": {
    "default_title": "Open MJ Automator Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.midjourney.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.midjourney.com/*"
  ]
}